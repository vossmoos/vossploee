# Example only — the app does not read this file. Copy to `.env` and fill in values there.

# --- App (VOSSPLOEE_*) ---
VOSSPLOEE_APP_NAME=Vossploee Task Orchestrator
VOSSPLOEE_DATABASE_PATH=data/tasks.db
# VOSSPLOEE_CHROMA_PATH=data/chroma
# Long-term memory uses OpenAI text-embedding-3-large (Chroma collection agent_memory_te3l); requires
# OPENAI_API_KEY or VOSSPLOEE_OPENAI_API_KEY (see Provider credentials below).
VOSSPLOEE_POLL_INTERVAL_SECONDS=1
VOSSPLOEE_API_PREFIX=/api
# HTTP API key (not hardcoded in application defaults — set here after `cp default.env .env`).
# Clients must send X-API-KEY matching this value (401/403 otherwise). Example value for local dev;
# replace for production. To disable HTTP key checks, set VOSSPLOEE_API_KEY= (empty).
VOSSPLOEE_API_KEY=
# Max queue01 roots the Decomposer may return in one POST /tasks (hourly monitoring fan-out).
# VOSSPLOEE_MAX_DECOMPOSED_ROOTS=168
# Comma-separated ids, or leave empty to enable every discovered capability package.
VOSSPLOEE_ENABLED_CAPABILITIES=core,brainstormer,newsroom,upworkmanager

# Required for real runs: pydantic-ai model id (provider:model_id).
# Use `test` for offline / CI-style runs without calling a provider API.
VOSSPLOEE_AGENT_MODEL=openai:gpt-5.4-mini
# Optional role-specific model overrides (fallback to VOSSPLOEE_AGENT_MODEL when empty):
# VOSSPLOEE_DECOMPOSER_MODEL=openai:gpt-5.4-mini
# VOSSPLOEE_ARCHITECT_MODEL=openai:gpt-5.4-mini
# VOSSPLOEE_IMPLEMENTER_MODEL=openai:gpt-5.4-mini

# --- Provider credentials ---
# Put these in `.env` as shown; Vossploee loads them and exposes OPENAI_API_KEY to the SDK.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# GEMINI_API_KEY=

# --- Core capability: IMAP/SMTP credentials (hosts/ports in capabilities/core/config.toml [imap]) ---
# UTF-8 characters (e.g. §) are supported in the password at runtime.
# If the value contains double quotes, wrap the whole value in single quotes, e.g.:
# VOSSPLOEE_CORE_IMAP_PASSWORD='pass"with"quotes-and-unicode-§'
# VOSSPLOEE_CORE_IMAP_USER=
# VOSSPLOEE_CORE_IMAP_PASSWORD=

# --- Upwork Manager capability ---
# Dashboard labels: "Key" -> VOSSPLOEE_UPWORK_CLIENT_ID, "Secret" -> VOSSPLOEE_UPWORK_CLIENT_SECRET.
# Neither Key nor Secret is a GraphQL Bearer token by itself.
#
# One-time browser OAuth (`uv run python uw_oauth.py`); then fully automated runs:
#   VOSSPLOEE_UPWORK_CLIENT_ID=  (Key)
#   VOSSPLOEE_UPWORK_CLIENT_SECRET=  (Secret)
#   VOSSPLOEE_UPWORK_REFRESH_TOKEN=  (from uw_oauth output — leave VOSSPLOEE_UPWORK_API_KEY unset)
# Optional static access token instead of refresh (expires sooner):
# VOSSPLOEE_UPWORK_API_KEY=
#
# client_credentials (Key+Secret only, no refresh) — many apps: unauthorized_client; use refresh instead.
#
# Optional; must match Upwork app Callback URL exactly (or "Missing or invalid redirect_uri"):
# VOSSPLOEE_UPWORK_OAUTH_REDIRECT=http://127.0.0.1:8719/callback
# If 127.0.0.1 fails, register http://localhost:8719/callback in Upwork and set that here.
# Optional GraphQL: VOSSPLOEE_UPWORK_API_TENANT_ID=
