# Example only — the app does not read this file. Copy to `.env` and fill in values there.

# --- App (VOSSPLOEE_*) ---
VOSSPLOEE_APP_NAME=Vossploee Task Orchestrator
VOSSPLOEE_DATABASE_PATH=data/tasks.db
VOSSPLOEE_POLL_INTERVAL_SECONDS=1
VOSSPLOEE_API_PREFIX=/api
# Comma-separated ids, or leave empty to enable every discovered capability package.
VOSSPLOEE_ENABLED_CAPABILITIES=consultant,brainstormer

# Required for real runs: pydantic-ai model id (provider:model_id).
# Use `test` for offline / CI-style runs without calling a provider API.
VOSSPLOEE_AGENT_MODEL=openai:gpt-5.4-nano

# --- Provider credentials ---
# Put these in `.env` as shown; Vossploee loads them and exposes OPENAI_API_KEY to the SDK.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# GEMINI_API_KEY=
